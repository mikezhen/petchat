rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Pet photos — owner-scoped path: pets/{petId}/{ownerUid}/photo.jpg
    // A write is only permitted when the {ownerUid} segment equals the
    // authenticated uploader's UID, so a signed-in user can never overwrite
    // another owner's photo. petId-first ordering groups every (current and
    // future) owner's photo under the pet, ready for an ownership-transfer
    // feature. The fixed `photo.jpg` filename caps each owner to one file.
    match /pets/{petId}/{ownerUid}/photo.jpg {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == ownerUid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Legacy pet photos uploaded before the owner-scoped path existed.
    // Read-only for backward compatibility; no new writes here.
    match /pets/{petId}/{fileName} {
      allow read: if true;
    }

    match /users/{userId}/avatar.jpg {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
