rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Server-enforced caps on free-form text so a client (even one using its
    // own valid token) can't bloat documents toward Firestore's 1 MiB ceiling.
    // Defaults via .get() keep missing fields from failing validation.
    function petWithinLimits(d) {
      return d.get('name', '').size() <= 100
        && d.get('breed', '').size() <= 100
        && d.get('color', '').size() <= 100
        && d.get('weight', '').size() <= 50
        && d.get('gender', '').size() <= 10
        && d.get('birthday', '').size() <= 30
        && d.get('description', '').size() <= 2000
        && d.get('medicalNotes', '').size() <= 5000
        && d.get('contacts', []).size() <= 5
        && d.get('vet', {}).get('name', '').size() <= 100
        && d.get('vet', {}).get('phone', '').size() <= 30;
    }

    function userWithinLimits(d) {
      return d.get('fullName', '').size() <= 100
        && d.get('phone', '').size() <= 30
        && d.get('email', '').size() <= 254;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && userWithinLimits(request.resource.data);
    }

    match /pets/{petId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && petWithinLimits(request.resource.data);
      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && petWithinLimits(request.resource.data);
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;

      match /scanEvents/{scanId} {
        allow create: if true;
        allow read: if request.auth != null
                    && get(/databases/$(database)/documents/pets/$(petId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
